// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String?
  role            UserRole  @default(USER)
  requirePasskey  Boolean   @default(false) // GLOBAL_ADMIN can enforce passkey-only auth for ADMINs
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  organizations   OrganizationMember[]
  websites        Website[]
  intakes         GetStartedIntake[]
  passkeyCredentials PasskeyCredential[]
  webauthnChallenge  WebauthnChallenge?

  notificationsReceived   Notification[]            @relation("NotificationsReceived")
  notificationsActed      Notification[]            @relation("NotificationsActed")
  notificationSettings    UserNotificationSettings?

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  GLOBAL_ADMIN
}

// Multi-tenancy for white-labeling
model Organization {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  whiteLabel        Boolean             @default(false)
  customDomain      String?
  branding          Json?               // Logo, colors, etc.
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Hierarchy fields
  parentId          String?
  partyAffiliation  PartyAffiliation?
  ownStatus         OrganizationStatus  @default(ACTIVE)
  canCreateChildren Boolean             @default(false)
  maxChildDepth     Int?                // null = unlimited depth from this node
  setupCompletedAt  DateTime?           // null = first-login modal not yet completed
  suspendedAt       DateTime?
  suspendedByOrgId  String?             // which org triggered the suspension (null = system admin)

  // Relations
  members           OrganizationMember[]
  invites           OrganizationInvite[]
  websites          Website[]
  intakes           GetStartedIntake[]

  parent            Organization?       @relation("OrgHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Organization[]      @relation("OrgHierarchy")

  ancestors         OrganizationAncestry[] @relation("AncestryDescendant")
  descendants       OrganizationAncestry[] @relation("AncestryAncestor")

  masterTenantMapping MasterTenantMapping?

  // Multi-parent co-ownership
  ownerships        OrganizationOwnership[] @relation("OwnershipParent")  // orgs this org owns
  coOwners          OrganizationOwnership[] @relation("OwnershipChild")   // this org's parent owners

  // Governance
  initiatedProposals  GovernanceProposal[]   @relation("ProposalInitiator")
  childProposals      GovernanceProposal[]   @relation("ProposalChild")
  governanceVotes     GovernanceVote[]       @relation("VoteVoter")
  governanceNotifs    GovernanceNotification[] @relation("NotifRecipient")

  // System permission policies assigned by system admins
  policyAssignments   OrgPolicyAssignment[]

  // Parent-org inherited policies (this org sets policies on children)
  policiesSet         OrgInheritedPolicy[]  @relation("PolicySetBy")
  // Policies set on this org by parent orgs
  policiesReceived    OrgInheritedPolicy[]  @relation("PolicyTarget")

  // Custom roles defined by this org's OWNER
  customRoles         OrgCustomRole[]

  notifications       Notification[]        @relation("OrgNotifications")

  @@map("organizations")
}

// Closure table: every ancestor→descendant pair at every depth
model OrganizationAncestry {
  ancestorId    String
  descendantId  String
  depth         Int   // 1 = direct parent, 2 = grandparent, …

  ancestor      Organization @relation("AncestryAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant    Organization @relation("AncestryDescendant", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  @@index([descendantId])
  @@index([ancestorId])
  @@map("organization_ancestry")
}

// Maps each party affiliation to its master/root tenant org
model MasterTenantMapping {
  id               String           @id @default(cuid())
  partyAffiliation PartyAffiliation @unique
  organizationId   String           @unique
  createdAt        DateTime         @default(now())

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("master_tenant_mappings")
}

enum PartyAffiliation {
  REPUBLICAN
  DEMOCRAT
  LIBERTARIAN
  GREEN
  INDEPENDENT
  NONPARTISAN
  OTHER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model OrganizationMember {
  id             String          @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole      @default(MEMBER)
  customRoleId   String?         // Only valid when role is MEMBER or ADMIN

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole     OrgCustomRole?  @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

/// A custom role defined by a tenant OWNER, always a strict subset of the org's effective policy.
model OrgCustomRole {
  id             String               @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String               @default("#6366f1") // tailwind indigo-500 default
  permissions    Json                 // Array of { resource: string, actions: string[] }
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        OrganizationMember[]

  @@unique([organizationId, name])
  @@map("org_custom_roles")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// Campaign Website
model Website {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  domain         String?
  templateId     String?
  status         WebsiteStatus  @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  organizationId String
  userId         String
  
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template       Template?      @relation(fields: [templateId], references: [id])
  
  buildJobs      BuildJob[]
  integrations   Integration[]
  pages          Page[]
  
  @@map("websites")
}

enum WebsiteStatus {
  DRAFT
  BUILDING
  AUDITING
  DEPLOYING
  PUBLISHED
  FAILED
}

// Templates
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  thumbnail   String?
  category    String
  tags        String[]
  isPublic    Boolean  @default(true)
  sourceCode  Json     // Initial structure, components
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  websites    Website[]
  
  @@map("templates")
}

// AI Pipeline Jobs
model BuildJob {
  id         String        @id @default(cuid())
  websiteId  String
  stage      BuildStage
  status     JobStatus     @default(PENDING)
  input      Json?
  output     Json?
  llmLogs    LLMLog[]
  error      String?
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime      @default(now())
  
  website    Website       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  
  @@map("build_jobs")
}

enum BuildStage {
  BUILDER        // 3+ LLM Ring
  AUDITOR_1      // Single LLM
  CICD_BUILDER   // 3+ LLM Ring
  AUDITOR_2      // Single LLM
  DEPLOYMENT
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

// LLM Execution Logs
model LLMLog {
  id          String   @id @default(cuid())
  buildJobId  String
  provider    String   // openai, anthropic, google
  model       String
  prompt      String   @db.Text
  response    String   @db.Text
  tokenCount  Int?
  latency     Int?     // milliseconds
  createdAt   DateTime @default(now())
  
  buildJob    BuildJob @relation(fields: [buildJobId], references: [id], onDelete: Cascade)
  
  @@map("llm_logs")
}

// Third-party Integrations
model Integration {
  id          String           @id @default(cuid())
  websiteId   String
  type        IntegrationType
  provider    String           // actblue, anedot, salesforce, hubspot
  config      Json             // API keys, endpoint configs
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  website     Website          @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  
  @@map("integrations")
}

enum IntegrationType {
  FUNDRAISING
  CRM
  EMAIL
  ANALYTICS
}

// Website Pages
model Page {
  id        String   @id @default(cuid())
  websiteId String
  path      String   // e.g., "/", "/donate", "/about"
  title     String
  content   Json     // Structured page content
  seo       Json?    // Meta tags, og tags
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  
  @@unique([websiteId, path])
  @@map("pages")
}

// Blog Posts
model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   @db.Text
  author      String
  coverImage  String?
  tags        String[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("blog_posts")
}

// Job Openings
model JobOpening {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  department  String
  location    String
  type        String   // Full-time, Part-time, Contract
  description String   @db.Text
  responsibilities String[]
  qualifications  String[]
  salary      String?
  applyUrl    String
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications JobApplication[]
  
  @@map("job_openings")
}

// Job Applications
model JobApplication {
  id               String   @id @default(cuid())
  jobOpeningId     String
  fullName         String
  email            String
  phone            String
  location         String?
  linkedInUrl      String?
  portfolioUrl     String?
  yearsExperience  Int?
  currentCompany   String?
  currentTitle     String?
  expectedSalary   String?
  startDate        String?
  workAuthorization String?
  coverLetter      String?
  additionalInfo   String?
  resumeFileName   String
  resumeFilePath   String
  resumeMimeType   String
  cvFileName       String
  cvFilePath       String
  cvMimeType       String
  status           String   @default("submitted")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  jobOpening       JobOpening @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)

  @@index([jobOpeningId])
  @@index([email])
  @@map("job_applications")
}

// Blog Newsletter Subscribers
model BlogSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  source    String?  // e.g. blog-page
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_subscribers")
}

// Get Started Intake Wizard Submissions
model GetStartedIntake {
  id                    String   @id @default(cuid())
  userId                String
  organizationId        String
  campaignName          String
  officeSought          String
  electionDate          String?
  timeline              String
  teamSize              String
  budgetRange           String
  donationPlatform      String?
  crmPlatform           String?
  emailPlatform         String?
  goals                 String[]
  privacyContact        String?
  incidentContact       String?
  dataResidency         String?
  teamInvites           String[]
  notes                 String?
  brandLogoFileName     String?
  brandLogoFilePath     String?
  brandLogoMimeType     String?
  campaignBriefFileName String
  campaignBriefFilePath String
  campaignBriefMimeType String
  complianceFileName    String?
  complianceFilePath    String?
  complianceMimeType    String?
  status                String   @default("submitted")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([campaignName])
  @@map("get_started_intakes")
}

// ─── Multi-Parent Co-Ownership & Governance ────────────────────────────────

// Many-to-many parent↔child ownership (replaces single parentId for governance)
model OrganizationOwnership {
  parentOrgId     String
  childOrgId      String
  isPrimary       Boolean            @default(false) // oldest/first parent
  status          OwnershipStatus    @default(ACTIVE)
  addedAt         DateTime           @default(now())
  addedByUserId   String?
  removedAt       DateTime?
  removedByUserId String?

  parentOrg       Organization       @relation("OwnershipParent", fields: [parentOrgId], references: [id], onDelete: Cascade)
  childOrg        Organization       @relation("OwnershipChild", fields: [childOrgId], references: [id], onDelete: Cascade)

  @@id([parentOrgId, childOrgId])
  @@index([childOrgId])
  @@index([parentOrgId])
  @@map("organization_ownerships")
}

enum OwnershipStatus {
  ACTIVE
  REMOVED
}

// System-wide key-value config store (admin-managed)
model SystemConfig {
  key             String   @id
  value           Json
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  @@map("system_config")
}

// Per-action-type voting rules (admin-configurable)
model GovernanceRuleSet {
  id            String              @id @default(cuid())
  actionType    GovernanceActionType @unique
  votingMode    VotingMode          @default(UNANIMOUS)
  quorumPercent Int?                // required when votingMode = QUORUM (e.g., 51 = >50%)
  rejectMode    RejectMode          @default(SINGLE_VETO)
  ttlDays       Int                 @default(7)
  isActive      Boolean             @default(true)
  updatedAt     DateTime            @updatedAt

  @@map("governance_rule_sets")
}

// A proposed change to a child org, requiring votes from all co-parents
model GovernanceProposal {
  id                  String               @id @default(cuid())
  childOrgId          String
  initiatorOrgId      String
  initiatorUserId     String
  actionType          GovernanceActionType
  actionPayload       Json                 // snapshot of what will change
  status              ProposalStatus       @default(PENDING_VOTES)
  // Rule snapshots at creation time — immune to subsequent rule changes
  votingMode          VotingMode
  quorumPercent       Int?
  rejectMode          RejectMode
  requiredVoterCount  Int                  // N parents at creation time
  expiresAt           DateTime
  createdAt           DateTime             @default(now())
  resolvedAt          DateTime?
  resolvedReason      String?

  childOrg            Organization         @relation("ProposalChild", fields: [childOrgId], references: [id], onDelete: Cascade)
  initiatorOrg        Organization         @relation("ProposalInitiator", fields: [initiatorOrgId], references: [id], onDelete: Cascade)

  votes               GovernanceVote[]
  notifications       GovernanceNotification[]

  @@index([childOrgId])
  @@index([initiatorOrgId])
  @@index([status])
  @@map("governance_proposals")
}

// One vote per parent org per proposal
model GovernanceVote {
  id           String       @id @default(cuid())
  proposalId   String
  voterOrgId   String
  voterUserId  String
  decision     VoteDecision
  comment      String?
  votedAt      DateTime     @default(now())

  proposal     GovernanceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voterOrg     Organization       @relation("VoteVoter", fields: [voterOrgId], references: [id], onDelete: Cascade)

  @@unique([proposalId, voterOrgId])
  @@index([voterOrgId])
  @@map("governance_votes")
}

// In-app notification per recipient org per governance event
model GovernanceNotification {
  id             String           @id @default(cuid())
  proposalId     String
  recipientOrgId String
  type           NotificationType
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  proposal       GovernanceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  recipientOrg   Organization       @relation("NotifRecipient", fields: [recipientOrgId], references: [id], onDelete: Cascade)

  @@index([recipientOrgId, readAt])
  @@index([proposalId])
  @@map("governance_notifications")
}

// ─── Governance Enums ──────────────────────────────────────────────────────

enum GovernanceActionType {
  SUSPEND
  REACTIVATE
  DEACTIVATE
  UPDATE_SETTINGS
  UPDATE_BRANDING
  UPDATE_INTEGRATIONS
  UPDATE_RBAC
  ADD_PARENT
  REMOVE_PARENT
  ADD_CHILD
  SET_CHILD_POLICY
  REMOVE_CHILD_POLICY
}

enum VotingMode {
  UNANIMOUS
  QUORUM
}

enum RejectMode {
  SINGLE_VETO    // any single REJECT kills the proposal
  MAJORITY_VETO  // only a majority REJECT kills the proposal
}

enum ProposalStatus {
  PENDING_VOTES
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum VoteDecision {
  APPROVE
  REJECT
}

enum NotificationType {
  VOTE_REQUESTED
  VOTE_CAST
  PROPOSAL_APPROVED
  PROPOSAL_REJECTED
  PROPOSAL_EXPIRED
  PROPOSAL_CANCELLED
}

// ─── Generic Notification Infrastructure ──────────────────────────────────────

enum NotificationEventType {
  // System-level (GLOBAL_ADMIN/ADMIN recipients)
  USER_CREATED
  USER_ROLE_CHANGED
  USER_DEACTIVATED
  POLICY_ASSIGNED
  POLICY_REVOKED
  SECURITY_ALERT
  SYSTEM_ANNOUNCEMENT
  // Org-level (org members as recipients)
  ORG_MEMBER_ADDED
  ORG_MEMBER_REMOVED
  ORG_ROLE_CHANGED
  ORG_POLICY_ASSIGNED
  // Governance (org members)
  GOVERNANCE_VOTE_REQUESTED
  GOVERNANCE_VOTE_CAST
  GOVERNANCE_PROPOSAL_APPROVED
  GOVERNANCE_PROPOSAL_REJECTED
  GOVERNANCE_PROPOSAL_EXPIRED
  // Campaign
  WEBSITE_PUBLISHED
  WEBSITE_BUILD_FAILED
}

model Notification {
  id          String                @id @default(cuid())
  type        NotificationEventType
  title       String
  body        String
  data        Json?
  recipientId String
  orgId       String?
  actorId     String?
  readAt      DateTime?
  createdAt   DateTime              @default(now())

  recipient   User                  @relation("NotificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  org         Organization?         @relation("OrgNotifications", fields: [orgId], references: [id], onDelete: Cascade)
  actor       User?                 @relation("NotificationsActed", fields: [actorId], references: [id])

  @@index([recipientId, readAt])
  @@index([orgId])
  @@index([createdAt])
  @@map("notifications")
}

model UserNotificationSettings {
  id            String                  @id @default(cuid())
  userId        String                  @unique
  inApp         Boolean                 @default(true)
  disabledTypes NotificationEventType[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_settings")
}

// ─── Organization Invites ──────────────────────────────────────────────────

// Organization Invites
model OrganizationInvite {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email           String
  role            String       @default("MEMBER")
  token           String       @unique @default(cuid())
  status          String       @default("PENDING") // PENDING | ACCEPTED | REVOKED | EXPIRED
  createdAt       DateTime     @default(now())
  expiresAt       DateTime
  invitedByUserId String?

  @@map("organization_invites")
}

// Server Application Logs
model ServerLog {
  id        String   @id @default(cuid())
  level     LogLevel
  message   String   @db.Text
  stack     String?  @db.Text
  source    String   // e.g., "auth", "api", "startup", "database"
  metadata  Json?
  createdAt DateTime @default(now())
  
  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@map("server_logs")
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

// ─── Passkeys (WebAuthn / FIDO2) ──────────────────────────────────────────────

// WebAuthn credential per user device. Multiple credentials allowed per user.
model PasskeyCredential {
  id              String    @id @default(cuid())
  userId          String
  credentialId    Bytes     @unique            // raw credential ID from WebAuthn
  publicKey       Bytes                        // COSE-encoded public key
  counter         Int       @default(0)        // signature counter (replay protection)
  deviceName      String?                      // user-provided label ("MacBook Touch ID")
  transports      String[]  @default([])       // ["internal","hybrid",…] from WebAuthn response
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  revokedByUserId String?                      // who revoked (null = self, else GLOBAL_ADMIN userId)

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkey_credentials")
}

// Transient challenge storage for WebAuthn flows (when Redis unavailable)
model WebauthnChallenge {
  userId    String   @id
  challenge String
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("webauthn_challenges")
}

// ─── System Permission Policies (System Admin → Tenant RBAC) ─────────────────

// Named set of resource/action rules that system admins apply to tenant orgs.
// rules Json shape: [{resource: string, actions: string[], allow: boolean}]
// Resources: members | branding | integrations | websites | settings | governance | hierarchy
// Actions: "invite" | "remove" | "update" | "publish" | "create" | "delete" | "*"
model SystemPermissionPolicy {
  id              String    @id @default(cuid())
  name            String
  description     String?
  rules           Json      // PolicyRule[]
  isDefault       Boolean   @default(false)   // auto-applied to every new org when true
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments     OrgPolicyAssignment[]

  @@map("system_permission_policies")
}

// Which system policies are assigned to which orgs.
model OrgPolicyAssignment {
  orgId           String
  policyId        String
  appliedByUserId String?
  appliedAt       DateTime  @default(now())

  organization    Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  policy          SystemPermissionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@id([orgId, policyId])
  @@index([policyId])
  @@map("org_policy_assignments")
}

// ─── Parent Tenant Policy Engine (Parent Org → Child Org restrictions) ────────

// A parent org can impose restrictions on a specific child org.
// rules Json shape: [{resource: string, actions: string[], allow: boolean}]
// Resources match those in SystemPermissionPolicy — layered on top of system policies.
model OrgInheritedPolicy {
  id              String    @id @default(cuid())
  parentOrgId     String
  targetOrgId     String
  rules           Json      // PolicyRule[]
  note            String?   // human-readable reason
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  parentOrg       Organization @relation("PolicySetBy", fields: [parentOrgId], references: [id], onDelete: Cascade)
  targetOrg       Organization @relation("PolicyTarget", fields: [targetOrgId], references: [id], onDelete: Cascade)

  @@unique([parentOrgId, targetOrgId])
  @@index([targetOrgId])
  @@map("org_inherited_policies")
}
