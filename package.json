{
  "name": "campaignsites",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered campaign website builder with multi-LLM pipeline",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build": "pnpm --recursive build",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm --recursive clean"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "turbo": "^1.12.4"
  },
  "packageManager": "pnpm@8.15.0"
}
