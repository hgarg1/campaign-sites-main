{
  "name": "campaignsites",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered campaign website builder with multi-LLM pipeline",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build": "pnpm --recursive build",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm --recursive clean"
  },
  "engines": {
    "node": "20.x",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "reactflow": "^11.11.4"
  }
}
