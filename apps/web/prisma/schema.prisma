// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  organizations OrganizationMember[]
  websites      Website[]
  intakes       GetStartedIntake[]
  
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  GLOBAL_ADMIN
}

// Multi-tenancy for white-labeling
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  whiteLabel  Boolean  @default(false)
  customDomain String?
  branding    Json?    // Logo, colors, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  members     OrganizationMember[]
  websites    Website[]
  intakes     GetStartedIntake[]
  
  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole   @default(MEMBER)
  
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// Campaign Website
model Website {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  domain         String?
  templateId     String?
  status         WebsiteStatus  @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  organizationId String
  userId         String
  
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template       Template?      @relation(fields: [templateId], references: [id])
  
  buildJobs      BuildJob[]
  integrations   Integration[]
  pages          Page[]
  
  @@map("websites")
}

enum WebsiteStatus {
  DRAFT
  BUILDING
  AUDITING
  DEPLOYING
  PUBLISHED
  FAILED
}

// Templates
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  thumbnail   String?
  category    String
  tags        String[]
  isPublic    Boolean  @default(true)
  sourceCode  Json     // Initial structure, components
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  websites    Website[]
  
  @@map("templates")
}

// AI Pipeline Jobs
model BuildJob {
  id         String        @id @default(cuid())
  websiteId  String
  stage      BuildStage
  status     JobStatus     @default(PENDING)
  input      Json?
  output     Json?
  llmLogs    LLMLog[]
  error      String?
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime      @default(now())
  
  website    Website       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  
  @@map("build_jobs")
}

enum BuildStage {
  BUILDER        // 3+ LLM Ring
  AUDITOR_1      // Single LLM
  CICD_BUILDER   // 3+ LLM Ring
  AUDITOR_2      // Single LLM
  DEPLOYMENT
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

// LLM Execution Logs
model LLMLog {
  id          String   @id @default(cuid())
  buildJobId  String
  provider    String   // openai, anthropic, google
  model       String
  prompt      String   @db.Text
  response    String   @db.Text
  tokenCount  Int?
  latency     Int?     // milliseconds
  createdAt   DateTime @default(now())
  
  buildJob    BuildJob @relation(fields: [buildJobId], references: [id], onDelete: Cascade)
  
  @@map("llm_logs")
}

// Third-party Integrations
model Integration {
  id          String           @id @default(cuid())
  websiteId   String
  type        IntegrationType
  provider    String           // actblue, anedot, salesforce, hubspot
  config      Json             // API keys, endpoint configs
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  website     Website          @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  
  @@map("integrations")
}

enum IntegrationType {
  FUNDRAISING
  CRM
  EMAIL
  ANALYTICS
}

// Website Pages
model Page {
  id        String   @id @default(cuid())
  websiteId String
  path      String   // e.g., "/", "/donate", "/about"
  title     String
  content   Json     // Structured page content
  seo       Json?    // Meta tags, og tags
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  
  @@unique([websiteId, path])
  @@map("pages")
}

// Blog Posts
model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   @db.Text
  author      String
  coverImage  String?
  tags        String[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("blog_posts")
}

// Job Openings
model JobOpening {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  department  String
  location    String
  type        String   // Full-time, Part-time, Contract
  description String   @db.Text
  responsibilities String[]
  qualifications  String[]
  salary      String?
  applyUrl    String
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications JobApplication[]
  
  @@map("job_openings")
}

// Job Applications
model JobApplication {
  id               String   @id @default(cuid())
  jobOpeningId     String
  fullName         String
  email            String
  phone            String
  location         String?
  linkedInUrl      String?
  portfolioUrl     String?
  yearsExperience  Int?
  currentCompany   String?
  currentTitle     String?
  expectedSalary   String?
  startDate        String?
  workAuthorization String?
  coverLetter      String?
  additionalInfo   String?
  resumeFileName   String
  resumeFilePath   String
  resumeMimeType   String
  cvFileName       String
  cvFilePath       String
  cvMimeType       String
  status           String   @default("submitted")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  jobOpening       JobOpening @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)

  @@index([jobOpeningId])
  @@index([email])
  @@map("job_applications")
}

// Blog Newsletter Subscribers
model BlogSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  source    String?  // e.g. blog-page
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_subscribers")
}

// Get Started Intake Wizard Submissions
model GetStartedIntake {
  id                    String   @id @default(cuid())
  userId                String
  organizationId        String
  campaignName          String
  officeSought          String
  electionDate          String?
  timeline              String
  teamSize              String
  budgetRange           String
  donationPlatform      String?
  crmPlatform           String?
  emailPlatform         String?
  goals                 String[]
  privacyContact        String?
  incidentContact       String?
  dataResidency         String?
  teamInvites           String[]
  notes                 String?
  brandLogoFileName     String?
  brandLogoFilePath     String?
  brandLogoMimeType     String?
  campaignBriefFileName String
  campaignBriefFilePath String
  campaignBriefMimeType String
  complianceFileName    String?
  complianceFilePath    String?
  complianceMimeType    String?
  status                String   @default("submitted")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([campaignName])
  @@map("get_started_intakes")
}

// Server Application Logs
model ServerLog {
  id        String   @id @default(cuid())
  level     LogLevel
  message   String   @db.Text
  stack     String?  @db.Text
  source    String   // e.g., "auth", "api", "startup", "database"
  metadata  Json?
  createdAt DateTime @default(now())
  
  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@map("server_logs")
}

enum LogLevel {
  INFO
  WARN
  ERROR
}
